{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JustPeek",
  "version": "0.1.0",
  "identifier": "com.sellsword.JustPeek",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "JustPeek",
        "width": 980,
        "height": 720,
        "resizable": true,
        "center": false,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
